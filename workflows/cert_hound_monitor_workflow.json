{
  "name": "cert_hound_monitor",
  "description": "Multi-client SSL certificate monitoring with tiered alerting and compliance reporting",
  "version": 1,
  "inputParameters": [
    "clients",
    "expiration_window_days"
  ],
  "tasks": [
    {
      "name": "prepare_fork_inputs",
      "taskReferenceName": "prepare_fork_inputs_ref",
      "type": "INLINE",
      "inputParameters": {
        "clients": "${workflow.input.clients}",
        "expiration_window_days": "${workflow.input.expiration_window_days}",
        "evaluatorType": "javascript",
        "expression": "(function() { var result = []; var clients = $.clients; for (var i = 0; i < clients.length; i++) { result.push({client_name: clients[i].client_name, urls: clients[i].urls, expiration_window_days: $.expiration_window_days}); } return {fork_inputs: result}; })()"
      }
    },
    {
      "name": "fan_out_clients",
      "taskReferenceName": "fan_out_clients_ref",
      "type": "FORK_JOIN_DYNAMIC",
      "inputParameters": {
        "forkTaskWorkflow": "cert_hound",
        "forkTaskWorkflowVersion": "1",
        "forkTaskInputs": "${prepare_fork_inputs_ref.output.result.fork_inputs}"
      }
    },
    {
      "name": "join_clients",
      "taskReferenceName": "join_clients_ref",
      "type": "JOIN"
    },
    {
      "name": "generate_cert_report",
      "taskReferenceName": "generate_cert_report_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "join_result": "${join_clients_ref.output}",
        "expiration_window_days": "${workflow.input.expiration_window_days}"
      }
    },
    {
      "name": "tiered_alert",
      "taskReferenceName": "tiered_alert_ref",
      "type": "SWITCH",
      "inputParameters": {
        "severity": "${generate_cert_report_ref.output.worst_severity}"
      },
      "evaluatorType": "value-param",
      "expression": "severity",
      "decisionCases": {
        "critical": [
          {
            "name": "alert_critical",
            "taskReferenceName": "alert_critical_ref",
            "type": "INLINE",
            "inputParameters": {
              "total_expiring": "${generate_cert_report_ref.output.total_expiring}",
              "evaluatorType": "javascript",
              "expression": "(function() { return {channel: '#security-critical', service: 'pagerduty', priority: 'P1', message: 'CRITICAL: ' + $.total_expiring + ' certificates need attention'}; })()"
            }
          }
        ],
        "warning": [
          {
            "name": "alert_warning",
            "taskReferenceName": "alert_warning_ref",
            "type": "INLINE",
            "inputParameters": {
              "total_expiring": "${generate_cert_report_ref.output.total_expiring}",
              "evaluatorType": "javascript",
              "expression": "(function() { return {channel: '#security-warnings', service: 'slack', message: 'WARNING: ' + $.total_expiring + ' certificates expiring within 30 days'}; })()"
            }
          }
        ]
      },
      "defaultCase": [
        {
          "name": "alert_info",
          "taskReferenceName": "alert_info_ref",
          "type": "INLINE",
          "inputParameters": {
            "total_checked": "${generate_cert_report_ref.output.total_checked}",
            "evaluatorType": "javascript",
            "expression": "(function() { return {channel: '#security-info', service: 'slack', message: 'All ' + $.total_checked + ' certificates are healthy'}; })()"
          }
        }
      ]
    }
  ],
  "outputParameters": {
    "all_details": "${generate_cert_report_ref.output.all_details}",
    "csv_report": "${generate_cert_report_ref.output.csv_report}",
    "total_checked": "${generate_cert_report_ref.output.total_checked}",
    "total_expiring": "${generate_cert_report_ref.output.total_expiring}",
    "worst_severity": "${generate_cert_report_ref.output.worst_severity}",
    "failed_clients": "${generate_cert_report_ref.output.failed_clients}",
    "alert": "${tiered_alert_ref.output.result}"
  },
  "schemaVersion": 2,
  "restartable": true,
  "workflowStatusListenerEnabled": false,
  "timeoutPolicy": "ALERT_ONLY",
  "timeoutSeconds": 0
}
